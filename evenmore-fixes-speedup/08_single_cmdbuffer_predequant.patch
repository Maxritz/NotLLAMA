+// ============================================================================
+// PHASE 2B: Pre-dequantize ALL weights at load time (ONE time, not per token)
+// ============================================================================
+bool InferenceEngine::initWeightBuffer() {
+    if (!model) return false;
+
+    size_t totalBytes = 0;
+    for (auto& t : model->tensors) {
+        if (t.format == QuantFormat::F16 || t.format == QuantFormat::F32) continue;
+        uint32_t nElements = 1;
+        for (auto d : t.shape) nElements *= d;
+        totalBytes += (size_t)nElements * sizeof(float);
+    }
+
+    if (totalBytes == 0) {
+        fprintf(stderr, "[weight-buffer] All weights already F16/F32, skipping pre-dequant.\n");
+        weightBufferSize = 0;
+        weightBufferAddr = 0;
+        return true;
+    }
+
+    fprintf(stderr, "[weight-buffer] allocating %zu MB for pre-dequantized weights\n",
+        totalBytes / 1024 / 1024);
+
+    VkBufferCreateInfo bufInfo = {};
+    bufInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+    bufInfo.size = totalBytes;
+    bufInfo.usage = VK_BUFFER_USAGE_STORAGE_BUFFER_BIT | VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+    bufInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+    VkResult r = vkCreateBuffer(ctx->device, &bufInfo, nullptr, &weightBuffer);
+    if (r != VK_SUCCESS) { fprintf(stderr, "[weight-buffer] vkCreateBuffer failed: %d\n", r); return false; }
+
+    VkMemoryRequirements memReq;
+    vkGetBufferMemoryRequirements(ctx->device, weightBuffer, &memReq);
+
+    VkPhysicalDeviceMemoryProperties memProps;
+    vkGetPhysicalDeviceMemoryProperties(ctx->physicalDevice, &memProps);
+
+    uint32_t memTypeIndex = UINT32_MAX;
+    for (uint32_t i = 0; i < memProps.memoryTypeCount; ++i) {
+        if ((memReq.memoryTypeBits & (1 << i)) &&
+            (memProps.memoryTypes[i].propertyFlags & VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT)) {
+            memTypeIndex = i; break;
+        }
+    }
+    if (memTypeIndex == UINT32_MAX) return false;
+
+    VkMemoryAllocateFlagsInfo flagsInfo = {};
+    flagsInfo.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_FLAGS_INFO;
+    flagsInfo.flags = VK_MEMORY_ALLOCATE_DEVICE_ADDRESS_BIT;
+
+    VkMemoryAllocateInfo allocInfo = {};
+    allocInfo.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO;
+    allocInfo.allocationSize = memReq.size;
+    allocInfo.memoryTypeIndex = memTypeIndex;
+    allocInfo.pNext = &flagsInfo;
+
+    r = vkAllocateMemory(ctx->device, &allocInfo, nullptr, &weightMemory);
+    if (r != VK_SUCCESS) return false;
+
+    vkBindBufferMemory(ctx->device, weightBuffer, weightMemory, 0);
+
+    VkBufferDeviceAddressInfo addrInfo = {};
+    addrInfo.sType = VK_STRUCTURE_TYPE_BUFFER_DEVICE_ADDRESS_INFO;
+    addrInfo.buffer = weightBuffer;
+    weightBufferAddr = vkGetBufferDeviceAddress(ctx->device, &addrInfo);
+
+    fprintf(stderr, "[weight-buffer] dequantizing %zu tensors...\n", model->tensors.size());
+    auto dqStart = std::chrono::steady_clock::now();
+
+    scheduler->beginBatch(0);
+    size_t offset = 0;
+    for (auto& t : model->tensors) {
+        if (t.format == QuantFormat::F16 || t.format == QuantFormat::F32) {
+            weightAddrs[t.name] = t.gpuAddress;
+            continue;
+        }
+        uint32_t nElements = 1;
+        for (auto d : t.shape) nElements *= d;
+        uint32_t elemPerChunk = 256 * 1024 * 32;
+        uint32_t elemOff = 0;
+        while (elemOff < nElements) {
+            uint32_t chunk = std::min(elemPerChunk, nElements - elemOff);
+            uint32_t chunkWg = (chunk + 31) / 32;
+            DequantizePushConstants pc = {};
+            pc.addrQuant = t.gpuAddress;
+            pc.addrOut = weightBufferAddr + offset + (uint64_t)elemOff * sizeof(float);
+            pc.nElements = chunk;
+            pc.quantFormat = static_cast<uint32_t>(t.format);
+            pc.totalThreads = chunkWg * 32;
+            pc.elementOffset = elemOff;
+            scheduler->dispatchInBatch(
+                pipelines->getPipeline("dequantize"),
+                pipelines->getLayout("dequantize"),
+                &pc, sizeof(pc), chunkWg, 1, 1);
+            elemOff += chunk;
+        }
+        weightAddrs[t.name] = weightBufferAddr + offset;
+        offset += (size_t)nElements * sizeof(float);
+    }
+    scheduler->endBatch(VK_NULL_HANDLE);
+    scheduler->syncAll();
+
+    auto dqEnd = std::chrono::steady_clock::now();
+    auto dqMs = std::chrono::duration_cast<std::chrono::milliseconds>(dqEnd - dqStart).count();
+    fprintf(stderr, "[weight-buffer] ready @ 0x%llx (%zu MB) in %lld ms\n",
+        (unsigned long long)weightBufferAddr, totalBytes / 1024 / 1024, (long long)dqMs);
+    weightBufferSize = totalBytes;
+    return true;
+}
