#version 460
#extension GL_EXT_subgroup_size_control : enable

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
layout(subgroup_size = 32) in;

layout(push_constant) uniform PC {
    uint count;
} pc;

layout(std430, binding = 0) buffer A { float a[]; };
layout(std430, binding = 1) buffer B { float b[]; };
layout(std430, binding = 2) buffer C { float c[]; };

shared float s_vals[256];

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < pc.count) {
        a[idx] = float(gl_SubgroupSize);
        b[idx] = float(gl_WorkGroupSize.x);
    }
}
